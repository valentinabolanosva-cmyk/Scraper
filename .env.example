# =============================================================
#  VARIABLES DE ENTORNO — Scrapear 2
#  Copia este archivo como ".env" y completa los valores.
#  NUNCA subas el .env real a un repo.
# =============================================================

# --- Supabase (obligatorio para subir_supabase.py y /analizar/) ---
# URL del proyecto: https://<tu-proyecto>.supabase.co
SUPABASE_URL=

# Clave anon o service_role (service_role solo si confías en el entorno)
SUPABASE_KEY=

# --- OpenAI (OPCIONAL — actualmente no se usa, reservado para futura integración LLM) ---
OPENAI_API_KEY=
